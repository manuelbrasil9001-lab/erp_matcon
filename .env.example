# ── Banco de Dados ─────────────────────────────────────────
# Railway preenche automaticamente ao adicionar o plugin PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Segurança JWT ──────────────────────────────────────────
# Troque por uma string aleatória longa em produção:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=troque-por-string-aleatoria-longa-em-producao

# ── CORS ───────────────────────────────────────────────────
# URL do seu frontend Vercel (sem barra no final)
ALLOWED_ORIGINS=https://erp-matcon.vercel.app,http://localhost:3000

# ── Bling API v3 (opcional — pode configurar pelo painel) ──
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
